# IMAP Settings
IMAP_HOST=imap.yourserver.com       # The hostname of your IMAP server
IMAP_PORT=993                       # IMAP port. 993 is the standard port for IMAP over SSL
IMAP_USERNAME=your@email.com        # Whatever your e-mail address is, or the portion to the left of @
IMAP_PASSWORD="yourpassword"        # Your email password wrapped in double quotes
IMAP_FOLDER=INBOX                   # The folder Boxwatchr will monitor for new mail
IMAP_POLL_INTERVAL=60               # How often Boxwatchr checks for new mail in seconds, used as a fallback if IMAP IDLE is not supported

# Logging
LOG_LEVEL=INFO                      # How verbose the logs should be. Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# Spam Settings
SPAM_THRESHOLD=5.0                  # The rspamd score at which Boxwatchr considers a message spam. Higher is more lenient, lower is stricter
SPAM_ACTION=move                    # What to do with messages that exceed the spam threshold. Options: move, delete, junk
SPAM_FOLDER=Junk                    # The folder spam is moved to when SPAM_ACTION is set to move

# Web Dashboard Settings
WEB_PORT=8080                       # The port the Boxwatchr web dashboard runs on
WEB_PASSWORD=                       # Password to access the web dashboard. Leave blank to disable password protection

# rspamd Settings
RSPAMD_HOST=127.0.0.1               # You should not need to modify this
RSPAMD_PORT=11333                   # ...or this