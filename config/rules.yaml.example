# =============================================================================
# boxwatchr Rules Configuration
# =============================================================================

# Rules are evaluated top to bottom. The first rule that matches an
# email wins and processing stops. Emails that do not match any rule
# are left completely alone.

# =============================================================================
# REQUIRED FIELDS
# =============================================================================

# Every rule must have all of the following fields or it will be skipped
# on startup and a warning will be logged.
#
#   name                        A unique name identifying the rule. Shown in logs and on
#                               the dashboard when a rule matches.
#   match                       Controls how multiple conditions are evaluated. Must be
#                               "all" or "any". See MATCH OPTIONS below.
#   learn                       Tells rspamd whether matching emails are spam or legitimate
#                               mail. Must be "spam" or "ham". See LEARNING below.
#   conditions                  A list of at least one condition. Each condition must have
#                               a field, an operator, and a value. See CONDITION FIELDS
#                               and CONDITION OPERATORS below.
#   actions                     A list of at least one action. Each action must have a type.
#                               Move actions also require a destination. See ACTIONS below.

# =============================================================================
# MATCH OPTIONS
# =============================================================================

# match: all                    Every condition in the rule must be true for it to trigger.
# match: any                    At least one condition must be true for it to trigger.
#
# If you leave out the match setting, it defaults to "all".

# =============================================================================
# CONDITION FIELDS
# =============================================================================

# Sender fields:
#   sender                      The full sender address. Example: tim@walmart.com
#   sender_local                The part before the @. Example: tim
#   sender_domain               The full domain including any subdomain.
#                               Example: mail.walmart.com
#   sender_domain_name          Everything to the left of the TLD, including
#                               any subdomain. Example: mail.walmart
#                               Note: Use sender_domain_root instead if you want
#                               to match just the registered domain name without
#                               worrying about subdomains.
#   sender_domain_root          The registered domain name only, with no subdomain
#                               and no TLD.
#                               Example: email.nfl.com gives "nfl"
#                               Example: mail.walmart.com gives "walmart"
#                               Example: support.bbc.co.uk gives "bbc"
#                               This is the recommended field for matching senders
#                               by company or service name.
#   sender_domain_tld           Just the TLD. Examples: com, org, net, co.uk, ru
#
# Recipient fields (matches if ANY recipient satisfies the condition):
#   recipient                   The full recipient address.
#   recipient_local             The part before the @.
#   recipient_domain            The full domain including any subdomain.
#   recipient_domain_name       Everything to the left of the TLD, including
#                               any subdomain.
#   recipient_domain_root       The registered domain name only, with no subdomain
#                               and no TLD. Same behavior as sender_domain_root.
#   recipient_domain_tld        Just the TLD.
#
# Other fields:
#   subject                     The email subject line.
#   raw_headers                 The full raw headers of the email. Useful for
#                               matching against headers that do not have their
#                               own dedicated field, such as List-Unsubscribe.
#
# Attachment fields (matches if ANY attachment satisfies the condition):
#   attachment_name             The full filename of the attachment.
#                               Example: invoice.pdf
#   attachment_extension        The file extension only, without the dot,
#                               lowercased. Example: pdf, exe, docx
#   attachment_content_type     The MIME type of the attachment.
#                               Example: application/pdf, image/jpeg
#
# To match emails that have any attachment at all, use is_empty on
# attachment_name with a value of false. See the example rules below.

# =============================================================================
# NORMALIZATION
# =============================================================================

# The following fields are automatically normalized before being compared
# against your rule values. Normalization strips everything that is not
# a letter or a digit, then lowercases the result.
#
#   sender_local                no-reply, no_reply, and noreply all match "noreply"
#   sender_domain_name          mail.walmart and mail-walmart both match "mailwalmart"
#   sender_domain_root          7-eleven matches "7eleven"
#   recipient_local             same behavior as sender_local
#   recipient_domain_name       same behavior as sender_domain_name
#   recipient_domain_root       same behavior as sender_domain_root
#
# This means you only need one rule to catch all common variations of
# an address. Your rule value should also be written without special
# characters since both sides are normalized before comparing.
#
# When normalization changes the match, boxwatchr logs exactly what
# happened. Example: "matched because 'no-reply' normalized to
# 'noreply' matches 'noreply'".
#
# All other fields (sender, sender_domain, sender_domain_tld, subject,
# raw_headers, and the equivalent recipient fields) are compared exactly
# as received, with only case folding applied. No normalization.

# =============================================================================
# CONDITION OPERATORS
# =============================================================================

# equals                        The field must match the value exactly (case insensitive,
#                               normalization applied where noted above).
#                               Example: sender_domain_root equals "walmart" matches
#                               tim@walmart.com and orders@mail.walmart.com but not
#                               tim@walmart-fake.com.
#
# contains                      The field must contain the value anywhere in it (case
#                               insensitive, normalization applied where noted above).
#                               Example: sender_local contains "newsletter" matches
#                               newsletter@example.com and our-newsletter@example.com.
#
# is_empty                      Checks whether the field has no value. Use true to match
#                               when the field is empty, or false to match when it is not.
#                               Works on any field including recipient fields (true means
#                               no recipients at all).
#                               Example: recipient is_empty true matches emails with no
#                               recipients in the envelope, which is a common spam indicator.

# =============================================================================
# ACTIONS
# =============================================================================

# Actions fall into two categories: non-terminal and terminal.
#
# Non-terminal actions do not change the message's location or UID. They can
# be combined with each other and with a terminal action. They always execute
# before any terminal action, regardless of the order you write them.
#
# Terminal actions move the message out of the watched folder, destroying its
# UID in the process. Only one terminal action is allowed per rule. Once a
# terminal action executes, no further actions are run.
#
# Rules with more than one terminal action, duplicate action types, or
# contradictory actions (mark_read + mark_unread) will be skipped on startup
# with a warning logged.
#
# --- Non-terminal actions ---
#
# Mark the email as read (sets the \Seen flag).
#
#   - type: mark_read
#
# Mark the email as unread (removes the \Seen flag).
#
#   - type: mark_unread
#
# --- Terminal actions ---
#
# Move the email to a folder. The folder must already exist on your
# mail server or the action will fail and boxwatchr will log an error.
#
#   - type: move
#     destination: FolderName
#
# Move the email to your trash folder as defined by IMAP_TRASH_FOLDER.
#
#   - type: delete
#
# Move the email to your spam folder as defined by IMAP_SPAM_FOLDER.
#
#   - type: junk

# =============================================================================
# LEARNING
# =============================================================================

# Every rule requires a learn field. This tells rspamd whether emails
# matching this rule should be treated as spam or legitimate mail. rspamd
# uses this feedback to improve its scoring accuracy over time.
#
# learn: spam                   Tells rspamd this email is spam. Future emails with similar
#                               characteristics will receive higher spam scores.
#
# learn: ham                    Tells rspamd this email is legitimate. Future emails with
#                               similar characteristics will receive lower spam scores.
#
# This field is required. Rules without it will be skipped on startup
# and a warning will be logged.

# =============================================================================
# EXAMPLE RULES
# =============================================================================

rules:
  # Catches no-reply, no_reply, noreply, do-not-reply, donotreply,
  # and any other variation since sender_local is normalized before
  # comparing. You only need the plain version in your rule value.
  - name: No reply addresses
    match: any
    learn: ham
    conditions:
      - field: sender_local
        operator: equals
        value: "noreply"
    actions:
      - type: move
        destination: No Reply

  # Move any email where the local part of the sender contains "newsletter"
  # to the Newsletters folder. Catches newsletter@walmart.com and
  # our-newsletter@example.org. Normalization means "our-newsletter"
  # and "ournewsletter" both match.
  - name: Move newsletters
    match: any
    learn: ham
    conditions:
      - field: sender_local
        operator: contains
        value: "newsletter"
    actions:
      - type: move
        destination: Newsletters

  # sender_domain_root correctly handles senders that use subdomains
  # for sending. email.nfl.com, mail.nfl.com, and nfl.com all give
  # a domain root of "nfl" so you only need one rule to catch them all.
  - name: NFL emails
    match: any
    learn: ham
    conditions:
      - field: sender_domain_root
        operator: equals
        value: "nfl"
    actions:
      - type: move
        destination: Sports

  # Move emails from Walmart that contain "receipt" in the subject
  # to the Walmart folder. Both conditions must be true since
  # match is set to all.
  - name: Walmart receipts
    match: all
    learn: ham
    conditions:
      - field: sender_domain_root
        operator: equals
        value: "walmart"
      - field: subject
        operator: contains
        value: "receipt"
    actions:
      - type: move
        destination: Walmart

  # Move emails from any .ru domain to trash.
  - name: Delete Russian TLD
    match: any
    learn: spam
    conditions:
      - field: sender_domain_tld
        operator: equals
        value: "ru"
    actions:
      - type: delete

  # Emails with no recipients in the envelope are almost always spam.
  - name: No recipients
    match: any
    learn: spam
    conditions:
      - field: recipient
        operator: is_empty
        value: true
    actions:
      - type: junk

  # raw_headers example. List-Unsubscribe is a header that legitimate
  # mailing lists include. Matching on it catches promotional emails
  # that slipped past the sender and subject checks above.
  - name: Mailing list emails
    match: any
    learn: ham
    conditions:
      - field: raw_headers
        operator: contains
        value: "list-unsubscribe"
    actions:
      - type: move
        destination: Newsletters

  # Action chaining example. Non-terminal actions always run first
  # regardless of the order written. This rule marks the email as read
  # and then moves it. You could write the actions in either order and
  # the behavior would be the same.
  - name: Mark receipts read and file them
    match: all
    learn: ham
    conditions:
      - field: subject
        operator: contains
        value: "receipt"
    actions:
      - type: mark_read
      - type: move
        destination: Receipts

  # Attachment examples.

  # Match any email that has at least one attachment.
  - name: Emails with attachments
    match: any
    learn: ham
    conditions:
      - field: attachment_name
        operator: is_empty
        value: false
    actions:
      - type: move
        destination: Attachments

  # Block emails with executable attachments. Using match: any means the
  # rule triggers if the email has either a .exe or a .bat attachment.
  - name: Dangerous attachments
    match: any
    learn: spam
    conditions:
      - field: attachment_extension
        operator: equals
        value: "exe"
      - field: attachment_extension
        operator: equals
        value: "bat"
    actions:
      - type: junk

  # Move emails with PDF attachments to a Documents folder.
  - name: PDF attachments
    match: any
    learn: ham
    conditions:
      - field: attachment_extension
        operator: equals
        value: "pdf"
    actions:
      - type: move
        destination: Documents

  # Match by MIME content type.
  - name: Spreadsheet attachments
    match: any
    learn: ham
    conditions:
      - field: attachment_content_type
        operator: equals
        value: "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
    actions:
      - type: move
        destination: Documents
